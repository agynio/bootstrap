kubeconfig_path = "../k8s/.kube/agyn-local-kubeconfig.yaml"
# System ingress routes through Istio on port 8080; Argo CD is reachable at http://argocd.agyn.dev:8080
argocd_server_addr    = "argocd.agyn.dev:8080"
# argocd_admin_username = "admin"
# argocd_admin_password = "admin"

platform_namespace       = "platform"
platform_repo_url        = "https://github.com/agynio/platform.git"
platform_target_revision = "v0.15.2"
platform_server_image_tag     = "0.15.2"
docker_runner_image_tag       = "0.15.2"
docker_runner_replica_count   = 1

# Optional: supply credentials for private Git repositories
# platform_repo_username = "x-access-token"
# platform_repo_password = "ghp_example"

platform_db_password        = "agents"
platform_db_pvc_size        = "5Gi"
litellm_db_password         = "change-me"
litellm_db_pvc_size         = "5Gi"
litellm_master_key          = "sk-dev-master"
litellm_salt_key            = "sk-dev-salt"
docker_runner_shared_secret = "change-me"
vault_pvc_size              = "5Gi"
registry_mirror_pvc_size    = "5Gi"

argocd_automated_sync_enabled = true
argocd_prune_enabled          = true
argocd_self_heal_enabled      = true
