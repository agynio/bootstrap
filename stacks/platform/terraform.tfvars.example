kubeconfig_path = "../k8s/.kube/agyn-local-kubeconfig.yaml"
# Argo CD Terraform provider uses kubectl port-forwarding by default.
# Override credentials here if needed.
# argocd_admin_username = "admin"
# argocd_admin_password = "admin"

platform_namespace         = "platform"
platform_chart_version     = "0.15.2"
docker_runner_chart_version = "0.1.1"
agent_state_chart_version  = "0.1.0"
token_counting_chart_version = "0.2.0"
postgres_chart_version     = "0.1.1"
docker_runner_replica_count = 1

# Optional overrides for image tags
# platform_server_image_tag = "0.15.2"
# docker_runner_image_tag   = "0.1.1"
# agent_state_image_tag     = "v0.1.0"
# token_counting_image_tag  = "v0.2.0"
# files_image_tag           = "0.1.1"

platform_db_password        = "agents"
platform_db_pvc_size        = "5Gi"
litellm_db_password         = "change-me"
litellm_db_pvc_size         = "5Gi"
agent_state_db_password     = "agentstate"
agent_state_db_pvc_size     = "5Gi"
litellm_master_key          = "sk-dev-master"
litellm_salt_key            = "sk-dev-salt"
# LiteLLM UI credentials are dev-only; defaults to admin/admin.
# litellm_ui_username       = "admin"
# litellm_ui_password       = "admin"
docker_runner_shared_secret = "change-me"
vault_pvc_size              = "5Gi"
registry_mirror_pvc_size    = "5Gi"

argocd_automated_sync_enabled = true
argocd_prune_enabled          = true
argocd_self_heal_enabled      = true

files_chart_version = "0.1.1"
files_db_password   = "files"
files_db_pvc_size   = "5Gi"
minio_root_user     = "minioadmin"
minio_root_password = "minioadmin"
minio_pvc_size      = "10Gi"
minio_bucket_name   = "files"
